# Database
MONGODB_URI=mongodb://localhost:27017/product_db

# Server Configuration
PORT=4002

# CHANGE: Remove legacy GraphQL service URL
# REMOVED: AUTH_SERVICE_URL=http://localhost:4001/graphql

# CHANGE: REST API URLs only
PRODUCT_API_URL=http://localhost:4002/api/products
AUTH_API_URL=http://localhost:4001/api/users

INTERNAL_JWT_SECRET=your-internal-service-secret-here

# CHANGE: Add Kafka broker configuration
KAFKA_BROKERS=localhost:9092
KAFKA_LOG_LEVEL=ERROR

# Local semantic search (Ollama embeddings)
SEARCH_SEMANTIC_ENABLED=true
SEARCH_EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=embeddinggemma
OLLAMA_TIMEOUT_MS=3500
SEARCH_SEMANTIC_MAX_PRODUCTS=800
SEARCH_SEMANTIC_MIN_SCORE=0.18
